NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Base Sepolia (84532) deployments
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_EXECUTOR_ADDRESS=
# Base Account / Smart Wallet popup URL override (local dev wallet service)
# Should include the /connect path (matches default https://keys.coinbase.com/connect)
NEXT_PUBLIC_BASE_ACCOUNT_WALLET_URL=http://localhost:3005/connect
NEXT_PUBLIC_POLICY_MANAGER_ADDRESS=0x0737154a090082d9f3Db45f1448C4291e2fBAA56
NEXT_PUBLIC_MORPHO_LEND_POLICY_ADDRESS=0x4172b79aB56c29152268f33E3F262Cd7358D4C5D
# Optional: starting block for PolicyInstalled event indexing (set this after redeploys)
NEXT_PUBLIC_POLICY_EVENTS_FROM_BLOCK=36747107

# Demo vault/token (Base Sepolia) — optional convenience vars
NEXT_PUBLIC_DEMO_USDC_ADDRESS=
NEXT_PUBLIC_DEMO_USDC_VAULT_ADDRESS=

# Server-only (for demo executor → sign + broadcast executions without user signatures)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
EXECUTOR_PRIVATE_KEY=

# Local dev policy config persistence
# - On install, the app stores policyConfig (bytes) by policyId in `web/.policy-store.json` (ignored by git)
# - On execute, the app loads from that store so you don’t have to paste policyConfig

